## Main zshrc — sources modular configs from ~/.config/zsh/

export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
ZSH_CONFIG="$XDG_CONFIG_HOME/zsh"

source "$ZSH_CONFIG/exports.zsh"
source "$ZSH_CONFIG/files.zsh"
source "$ZSH_CONFIG/git.zsh"
source "$ZSH_CONFIG/docker.zsh"
source "$ZSH_CONFIG/system.zsh"
source "$ZSH_CONFIG/plugins.zsh"
source "$ZSH_CONFIG/cheat.zsh"
